# --- SERVER SETTINGS ---
PORT=5000
NODE_ENV=development

# --- CLIENT ---
# The URL of your frontend application (used for CORS)
CLIENT_URL=http://localhost:3000

# --- DATABASE (PostgreSQL) ---
# Replace with your actual PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/classroom_attendance?schema=public

# --- AUTHENTICATION (RBAC) ---
# Secret key for generating JSON Web Tokens (JWT) for student/teacher login sessions
JWT_SECRET=super_secret_jwt_key_for_academic_demo
JWT_EXPIRES_IN=1d

# --- GEO-LOCATION / MAPS (Optional) ---
# If you use the Haversine formula on the backend, you don't strictly need an API key for distances.
# However, if you want to render a map UI (like Google Maps) on the frontend:
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
